    "faviconPath": "/favicon.png",
    "branding": {
      "display": "logo-and-text",
      "logoPath": "/favicon.png",
      "logoAlt": "MiniWiki logo",
      "text": "MiniWiki",
      "logoClassName": "h-7 w-auto"
    },
    "wikiPreset": "docs",
    "defaultTemplate": "midnight"
  },
  "templates": {
    "defaultTemplate": "default",
    "defaults": {
      "aura": {},
      "forest": {},
      "guide": {
        "level": "Guide",
        "audience": "Developers"
      },
      "landing": {
        "cta": {
          "label": "Open Usage Guide",
          "href": "/guides/usage"
        },
        "features": [
          { "title": "MDX Content", "description": "Write docs in MDX with embedded React components." },
          { "title": "Config-Driven", "description": "Manage nav and site settings from JSON files." },
          { "title": "Template System", "description": "Choose page templates from frontmatter." }
        ]
      },
      "midnight": {},
      "reference": {
        "version": "v1",
        "sections": []
      }
    },
    "registry": {
      "aura": {
        "name": "Aura Template",
        "description": "Cozy faint magenta/pink content shell in dark mode."
      },
      "default": {
        "name": "Default Template",
        "description": "Standard prose layout for most wiki pages."
      },
      "forest": {
        "name": "Forest Template",
        "description": "Subtle emerald-tinted content shell for dark mode."
      }
