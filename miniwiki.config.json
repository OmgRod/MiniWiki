            { "label": "GitHub", "url": "https://github.com/OmgRod" },
            { "label": "MiniWiki Repository", "url": "https://github.com/OmgRod/MiniWiki" },
            { "label": "YouTube", "url": "https://www.youtube.com/@OmgRodYT" },
            { "label": "X / Twitter", "url": "https://x.com/0mgRod" },
            { "label": "Discord", "url": "https://discord.gg/vK3DuqJwyW" },
            { "label": "Email", "url": "mailto:rod@omgrod.me" }
          ]
        }
