{
  "siteName": "MiniWiki",
  "siteDescription": "Official MiniWiki template documentation.",
  "titleSuffix": "MiniWiki Docs",
  "faviconPath": "/favicon.png",
  "branding": {
    "display": "logo-and-text",
    "logoPath": "/favicon.png",
    "logoAlt": "MiniWiki logo",
    "text": "MiniWiki",
    "logoClassName": "h-7 w-auto"
  },
  "wikiPreset": "portal",
  "header": {
    "showSearch": true,
    "showDarkModeToggle": true,
    "searchPlaceholder": "Search docs..."
  },
  "pageTemplates": {
    "enabled": false,
    "defaultTemplate": "default"
  },
  "editPage": {
    "enabled": true,
    "provider": "github",
    "repository": "OmgRod/MiniWiki",
    "branch": "main",
    "contentPath": "content",
    "text": "Edit this page"
  },
  "layout": {
    "maxWidthClass": "max-w-7xl",
    "sidebarWidthClass": "md:w-72"
  }
}
